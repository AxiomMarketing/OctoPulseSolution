{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "printful/shipping-rates-request",
  "title": "Printful Shipping Rates Request",
  "description": "Request body for POST /shipping/rates",
  "type": "object",
  "required": ["recipient", "items"],
  "properties": {
    "recipient": {
      "type": "object",
      "required": ["country_code"],
      "properties": {
        "address1":     { "type": "string" },
        "city":         { "type": "string" },
        "country_code": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "state_code":   { "type": "string" },
        "zip":          { "type": "string" },
        "phone":        { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["quantity"],
        "properties": {
          "variant_id":          { "type": "integer" },
          "sync_variant_id":     { "type": "integer" },
          "external_variant_id": { "type": "string" },
          "quantity":            { "type": "integer", "minimum": 1 },
          "value":               { "type": "string", "description": "Retail value for customs" }
        }
      }
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "EUR" },
    "locale":   { "type": "string", "example": "fr_FR" }
  },
  "additionalProperties": false
}
